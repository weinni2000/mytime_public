<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_country_form_guest_registration" model="ir.ui.view">
        <field name="name">res.country.form.guest_registration</field>
        <field name="model">res.country</field>
        <field name="inherit_id" ref="base.view_country_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='currency_id']" position="after">
                <field name="preferred_guest_registration"/>
            </xpath>
        </field>
    </record>

    <record id="action_set_default_preferred_guest_registration" model="ir.actions.server">
        <field name="name">Reset Default Preferred Countries (Guest Registration)</field>
        <field name="model_id" ref="base.model_res_country"/>
        <field name="binding_model_id" ref="base.model_res_country"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">model.action_set_default_preferred_guest_registration()</field>
    </record>
</odoo>
