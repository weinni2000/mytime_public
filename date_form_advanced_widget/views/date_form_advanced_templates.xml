<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template id="date_form_advanced_page"
        name="Date Form Advanced">
        <t t-call="website.layout">
            <div id="wrap"
                class="oe_structure oe_empty">
                <section class="s_title_form o_cc o_cc2 pt64 pb48 o_colored_level"
                    data-snippet="s_title_form"
                    data-name="Titel Formular">
                    <div class="o_container_small">
                        <h2 class="text-center o_default_snippet_text">Kontaktieren Sie uns</h2>
                        <p class="text-center lead o_default_snippet_text">Nehmen Sie Kontakt zu Ihren Kunden auf, um ihnen einen besseren Service zu bieten. Sie können die Formularfelder ändern, um genauere Informationen zu erhalten.</p>
                        <section class="s_website_form pt16 pb16"
                            data-vcss="001"
                            data-snippet="s_website_form"
                            data-name="Formular">
                            <div class="container-fluid">
                                <form action="/website/form/"
                                    method="post"
                                    enctype="multipart/form-data"
                                    class="o_mark_required"
                                    data-mark="*"
                                    data-pre-fill="true"
                                    data-model_name="mail.mail"
                                    data-success-mode="redirect"
                                    data-success-page="/contactus-thank-you">
                                    <div class="s_website_form_rows row s_col_no_bgcolor">

                                        <div data-name="Field"
                                            class="s_website_form_field mb-3 col-12 s_website_form_custom s_website_form_required"
                                            data-type="char"
                                            data-translated-name="Feld">
                                            <div class="row s_col_no_resize s_col_no_bgcolor">
                                                <label class="col-form-label col-sm-auto s_website_form_label"
                                                    style="width: 200px"
                                                    for="ox8l7y5unw7">
                                                    <span class="s_website_form_label_content">Ihr Name</span>
                                                    <span class="s_website_form_mark">  *</span>
                                                </label>
                                                <div class="col-sm">
                                                    <input class="form-control s_website_form_input"
                                                        type="text"
                                                        name="name"
                                                        required=""
                                                        value=""
                                                        placeholder=""
                                                        id="ox8l7y5unw7"
                                                        data-fill-with="name"/>
                                                </div>
                                            </div>
                                        </div>
                                        <div data-name="Field"
                                            class="s_website_form_field mb-3 col-12 s_website_form_custom"
                                            data-type="tel"
                                            data-translated-name="Feld">
                                            <div class="row s_col_no_resize s_col_no_bgcolor">
                                                <label class="col-form-label col-sm-auto s_website_form_label"
                                                    style="width: 200px"
                                                    for="oh013lste7qd">
                                                    <span class="s_website_form_label_content">Telefon</span>
                                                </label>
                                                <div class="col-sm">
                                                    <input class="form-control s_website_form_input"
                                                        type="tel"
                                                        name="phone"
                                                        value=""
                                                        placeholder=""
                                                        id="oh013lste7qd"
                                                        data-fill-with="phone"/>
                                                </div>
                                            </div>
                                        </div>
                                        <div data-name="Field"
                                            class="s_website_form_field mb-3 col-12 s_website_form_model_required"
                                            data-type="email"
                                            data-translated-name="Feld">
                                            <div class="row s_col_no_resize s_col_no_bgcolor">
                                                <label class="col-form-label col-sm-auto s_website_form_label"
                                                    style="width: 200px"
                                                    for="o78rto59vhiw">
                                                    <span class="s_website_form_label_content">Ihre E-Mail</span>
                                                    <span class="s_website_form_mark">  *</span>
                                                </label>
                                                <div class="col-sm">
                                                    <input class="form-control s_website_form_input"
                                                        type="email"
                                                        name="email_from"
                                                        required=""
                                                        value=""
                                                        placeholder=""
                                                        id="o78rto59vhiw"
                                                        data-fill-with="email"/>
                                                </div>
                                            </div>
                                        </div>
                                        <div data-name="Field"
                                            class="s_website_form_field mb-3 col-12 s_website_form_custom"
                                            data-type="char"
                                            data-translated-name="Feld">
                                            <div class="row s_col_no_resize s_col_no_bgcolor">
                                                <label class="col-form-label col-sm-auto s_website_form_label"
                                                    style="width: 200px"
                                                    for="orda9yqsbksq">
                                                    <span class="s_website_form_label_content">Ihr Unternehmen</span>
                                                </label>
                                                <div class="col-sm">
                                                    <input class="form-control s_website_form_input"
                                                        type="text"
                                                        name="company"
                                                        value=""
                                                        placeholder=""
                                                        id="orda9yqsbksq"
                                                        data-fill-with="commercial_company_name"/>
                                                </div>
                                            </div>
                                        </div>
                                        <div data-name="Field"
                                            class="s_website_form_field mb-3 col-12 s_website_form_model_required"
                                            data-type="char"
                                            data-translated-name="Feld">
                                            <div class="row s_col_no_resize s_col_no_bgcolor">
                                                <label class="col-form-label col-sm-auto s_website_form_label"
                                                    style="width: 200px"
                                                    for="odsqgt3w52nd">
                                                    <span class="s_website_form_label_content">Betreff</span>
                                                    <span class="s_website_form_mark">  *</span>
                                                </label>
                                                <div class="col-sm">
                                                    <input class="form-control s_website_form_input"
                                                        type="text"
                                                        name="subject"
                                                        required=""
                                                        value=""
                                                        placeholder=""
                                                        id="odsqgt3w52nd"/>
                                                </div>
                                            </div>
                                        </div>
                                        <t t-call="date_form_advanced_widget.date_form_advanced_date_field"/>
                                        <div data-name="Field"
                                            class="s_website_form_field mb-3 col-12 s_website_form_custom s_website_form_required"
                                            data-type="text"
                                            data-translated-name="Feld">
                                            <div class="row s_col_no_resize s_col_no_bgcolor">
                                                <label class="col-form-label col-sm-auto s_website_form_label"
                                                    style="width: 200px"
                                                    for="obxsn88inmkn">
                                                    <span class="s_website_form_label_content">Ihre Frage</span>
                                                    <span class="s_website_form_mark">  *</span>
                                                </label>
                                                <div class="col-sm">
                                                    <textarea class="form-control s_website_form_input"
                                                        name="description"
                                                        required=""
                                                        placeholder=""
                                                        id="obxsn88inmkn"
                                                        rows="3"/>
                                                </div>
                                            </div>
                                        </div>
                                        <div data-name="Field"
                                            class="s_website_form_field mb-3 col-12 s_website_form_dnone">
                                            <div class="row s_col_no_resize s_col_no_bgcolor">
                                                <label class="col-form-label col-sm-auto s_website_form_label"
                                                    style="width: 200px">
                                                    <span class="s_website_form_label_content"/>
                                                </label>
                                                <div class="col-sm">
                                                    <input type="hidden"
                                                        class="form-control s_website_form_input"
                                                        name="email_to"
                                                        value="info@yourcompany.example.com"/>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="mb-0 py-2 col-12 s_website_form_submit text-end s_website_form_no_submit_label"
                                            data-name="Submit Button">
                                            <div style="width: 200px;"
                                                class="s_website_form_label"/>
                                            <span id="s_website_form_result"/>
                                            <a href="#"
                                                role="button"
                                                class="btn btn-primary s_website_form_send o_default_snippet_text">Absenden</a>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </section>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <template id="date_form_advanced_date_field"
        name="Date Form Advanced Date Field">
        <div data-name="Field"
            class="s_website_form_field mb-3 col-12 s_website_form_custom"
            data-type="date"
            data-translated-name="Feld">
            <div class="row s_col_no_resize s_col_no_bgcolor">
                <label class="col-form-label col-sm-auto s_website_form_label"
                    style="width: 200px"
                    for="ou7e832t1jz">
                    <span class="s_website_form_label_content">Benutzerdefinierter Text</span>
                </label>
                <div class="col-sm">
                    <input type="date"
                        class="form-control s_website_form_input"
                        name="Benutzerdefinierter Text"
                        value=""
                        id="ou7e832t1jz"/>
                </div>
            </div>
        </div>
    </template>
</odoo>
